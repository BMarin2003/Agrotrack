{
  "name": "agrotrack-back",
  "version": "0.1.0",
  "engines": {
    "bun": "1.3.5"
  },
  "scripts": {
    "start": "bun build/main.js",
    "dev": "bun run --watch --watch-path src src/index.ts",
    "dev:debug": "bun run --watch --inspect src/index.ts",
    "build": "bun build src/index.ts --target=bun --outfile=build/main.js --env=inline",
    "tsc": "bunx tsc --noEmit",
    "dev:mock": "MOCK_GATEWAY_IDENTIFIER=GW-001 MOCK_SENSOR_COUNT=3 bun run --watch src/index.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "dotenv": "^17.3.1",
    "elysia": "1.4.25",
    "jsonwebtoken": "9.0.3",
    "mqtt": "^5.10.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "9.0.10",
    "bun-types": "latest"
  },
  "module": "src/index.js",
  "packageManager": "bun@1.3.9"
}
