# NODE_ENV=production activa la conexión al broker MQTT y el watchdog
NODE_ENV=development

PORT=3000

# ─── Supabase PostgreSQL (Session Pooler — IPv4) ─────────────────────────────
# Obtener de: Supabase Dashboard → Settings → Database → Session Pooler
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.<project-ref>
DB_PASSWORD=<tu-password-de-bd>
DB_MAX_POOL_SIZE=10
DB_SSL=true

# ─── Supabase API ─────────────────────────────────────────────────────────────
# Obtener de: Supabase Dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRE_IN=604800

# ─── MQTT (solo en production) ────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=agrotrack-server
# Si el dispositivo publica en un topic fijo (no wildcard), configurar ambas:
MQTT_TOPIC_SUBSCRIBE=
MQTT_GATEWAY_UID=

TEAM_NAME=Corall D&R
TZ=America/Lima

# ─── Mock Gateway legacy (solo en development, si MQTT_ENABLED=false) ────────
MOCK_GATEWAY_IDENTIFIER=GW-001
MOCK_SENSOR_COUNT=6
MOCK_INTERVAL_MS=5000

# ─── Flota simulada (independiente de MQTT_ENABLED) ──────────────────────────
# Corre en paralelo al backend y pasa por el mismo camino de ingesta que un
# gateway real (auto-registro, BD, RulesEngine, Watchdog, WS) — para probar
# la app de punta a punta mientras no hay hardware Twarm transmitiendo.
MOCK_FLEET_ENABLED=false
MOCK_FLEET_GATEWAYS=12
MOCK_FLEET_SENSORS_PER_GATEWAY=15
MOCK_FLEET_INTERVAL_MS=15000
